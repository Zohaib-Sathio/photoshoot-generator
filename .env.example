# ------------------------------------------------------------------
# Image provider — "gemini" (default) or "openai"
# ------------------------------------------------------------------
IMAGE_PROVIDER=gemini

# ------------------------------------------------------------------
# Google Gemini — Nano Banana Pro (gemini-3-pro-image-preview)
# Higher quality + better instruction-following than 2.5 flash image.
# ------------------------------------------------------------------
GEMINI_API_KEY=
# Optional overrides:
# GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# Resolution: 512 | 1K | 2K | 4K   (uppercase K required)
# Default is 1K for cost control; bump to 2K/4K for final renders.
# GEMINI_IMAGE_SIZE=1K
# GEMINI_ASPECT_RATIO=4:5

# ------------------------------------------------------------------
# OpenAI — gpt-image-2 (restricted to verified orgs as of 2026)
# ------------------------------------------------------------------
OPENAI_API_KEY=
# Optional overrides:
# OPENAI_IMAGE_MODEL=gpt-image-2
# OPENAI_IMAGE_SIZE=1024x1536
